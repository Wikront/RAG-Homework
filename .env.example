# ── LLM (LM Studio / any OpenAI-compatible endpoint) ─────────────────────────
# Base URL of the chat completion server (LM Studio default: port 1234).
# Inside Docker use host.docker.internal to reach the host machine.
LLM_API_BASE=http://host.docker.internal:<LM_STUDIO_PORT>/v1

# API key — LM Studio accepts any non-empty string.
LLM_API_KEY=<ANY_STRING_OR_REAL_API_KEY>

# Exact model identifier shown in LM Studio (or your cloud provider).
LLM_MODEL_NAME=<CHAT_MODEL_IDENTIFIER>

# ── Embeddings ────────────────────────────────────────────────────────────────
# "openai" = use an OpenAI-compatible /v1/embeddings endpoint (e.g. LM Studio)
# "local"  = use sentence-transformers inside the container (no server needed)
EMBEDDING_BACKEND=openai

# Embedding model identifier loaded in LM Studio (or sentence-transformers name).
EMBEDDING_MODEL=<EMBEDDING_MODEL_IDENTIFIER>

# Optional: override if the embedding server differs from the chat server.
# EMBEDDING_API_BASE=http://host.docker.internal:<EMBEDDING_PORT>/v1
# EMBEDDING_API_KEY=<EMBEDDING_API_KEY>

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Service name from docker-compose.yml (used inside Docker).
# Leave blank to use a local PersistentClient instead of HTTP.
CHROMA_HOST=chroma
CHROMA_PORT=8000

# Path used only in local (non-Docker) mode; ignored when CHROMA_HOST is set.
CHROMA_PERSIST_DIR=.chroma

# ── Collection ────────────────────────────────────────────────────────────────
COLLECTION_NAME=rag

# ── Data paths ────────────────────────────────────────────────────────────────
# Inside the container; mapped from ./data on the host via the volume mount.
DATA_DIR=/app/data
